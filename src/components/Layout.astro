---
import "katex/dist/katex.min.css";
// Imported in original cascade order — do not reorder (responsive overrides
// depend on coming after their base rules).
import "../styles/base.css";
import "../styles/home.css";
import "../styles/chapter.css";
import "../styles/question.css";
import "../styles/footer.css";
import "../styles/study.css";
import "../styles/responsive.css";

interface Props {
  title: string;
}
const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <!-- Google Analytics 4 -->
    <script
      is:inline
      async
      src="https://www.googletagmanager.com/gtag/js?id=G-163M4VJ1VD"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        dataLayer.push(arguments);
      }
      gtag("js", new Date());
      gtag("config", "G-163M4VJ1VD");
    </script>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <!-- set study mode before paint (default: review = answers shown) -->
    <script is:inline>
      try {
        document.documentElement.dataset.mode =
          localStorage.getItem("fofm_mode") === "test" ? "test" : "review";
      } catch (e) {
        document.documentElement.dataset.mode = "review";
      }
    </script>
  </head>
  <body>
    <div id="presence-bar" aria-live="polite"></div>
    <slot />
    <script>
      import "../lib/client/main.ts";
    </script>
  </body>
</html>
